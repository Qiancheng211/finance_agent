# Qwen / DashScope OpenAI-compatible API
DASHSCOPE_API_KEY=
BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# DeepSeek is optional. Keep it only if you switch models in config.py.
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Mem0 long-term memory. Optional; the app runs without it.
MEM0_API_KEY=

# PostgreSQL business database. Required.
# Fill with your SQLAlchemy PostgreSQL URL.
FINANCE_DATABASE_URL=
